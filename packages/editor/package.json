{
  "name": "editor",
  "version": "0.1.0",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "test": "vitest run --passWithNoTests src",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "actor-core": "0.1.0",
    "runtime-core": "0.1.0",
    "ui-framework": "0.1.0"
  },
  "devDependencies": {
    "actor-input": "0.1.0"
  }
}
