{
  "name": "editor",
  "version": "0.1.0",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "src/**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./debug/debug-log.css": "./src/debug/debug-log.css",
    "./hierarchy/hierarchy.css": "./src/hierarchy/hierarchy.css",
    "./inspector/inspector.css": "./src/inspector/inspector.css",
    "./scene/scene-window.css": "./src/scene/scene-window.css"
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "test": "vitest run --passWithNoTests src",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "actor-core": "0.1.0",
    "actor-input": "0.1.0",
    "runtime-core": "0.1.0",
    "ui-framework": "0.1.0"
  }
}
