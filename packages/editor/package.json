{
  "name": "editor",
  "version": "0.1.0",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "src/**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./inspector/inspector.css": "./src/inspector/inspector.css",
    "./scene/scene-window.css": "./src/scene/scene-window.css",
    "./camera3/camera3-gizmo.css": "./src/camera3/camera3-gizmo.css"
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "test": "vitest run --passWithNoTests src",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "actor-system": "0.1.0",
    "foundation": "0.1.0",
    "runtime-core": "0.1.0",
    "three": "^0.181.2",
    "ui-framework": "0.1.0"
  },
  "devDependencies": {
    "@types/three": "^0.184.1"
  }
}
